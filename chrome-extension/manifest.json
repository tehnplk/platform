{
  "manifest_version": 3,
  "name": "PLK Platform Chat Badge",
  "description": "Shows unread admin chat messages from PLK Platform on the toolbar badge.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": [
    "https://platform.plkhealth.go.th/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "PLK Platform Chat",
    "default_popup": "popup.html"
  }
}
